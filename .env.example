# =============================================================
# Alumni Influencers Platform - Environment Configuration
# =============================================================
# Example environment configuration for the project.

# ----- Application Settings -----
# Runtime environment.
# Supported values: development | testing | production
CI_ENV=development

# Public base URL of the application.
# A trailing slash is required for CodeIgniter URL helpers.
BASE_URL=http://localhost:8080/

# ----- Database Settings -----
# MySQL host
DB_HOST=localhost
# MySQL application username
DB_USER=alumni_user
# MySQL application password
DB_PASS=Alumni@2024Secure
# Application database name
DB_NAME=alumni_platform

# ----- Email Settings -----
# SMTP configuration for verification, password reset, and winner notification emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_CRYPTO=tls
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# Sender address for outgoing mail
SMTP_FROM=noreply@westminster.ac.uk
# Sender display name for outgoing mail
SMTP_FROM_NAME=Alumni Influencers Platform

# ----- Security Settings -----
# Registration is limited to this email domain
UNIVERSITY_DOMAIN=westminster.ac.uk

# Session idle timeout in seconds
SESSION_TIMEOUT=7200

# CodeIgniter logging level
# 0=off, 1=error, 2=debug+error, 3=info+debug+error, 4=all
LOG_THRESHOLD=2

# Email verification token lifetime in hours
VERIFICATION_TOKEN_EXPIRY=24
# Password reset token lifetime in hours
RESET_TOKEN_EXPIRY=1

# Maximum requests per minute for sensitive authentication flows
RATE_LIMIT=60

# Allowed browser origin for API CORS headers
CORS_ALLOWED_ORIGIN=https://localhost

# Default scope assigned when a new API client is created by an admin
# Supported values are validated by the application
DEFAULT_API_SCOPE=featured:read,alumni:read

# Maximum Alumni-of-the-Day wins per month before the event-based bonus rule applies
MAX_FEATURES_PER_MONTH=3

# ----- Upload Settings -----
# Maximum uploaded profile-image size in KB
MAX_IMAGE_SIZE=2048
# Maximum uploaded image width in pixels
MAX_IMAGE_WIDTH=4000
# Maximum uploaded image height in pixels
MAX_IMAGE_HEIGHT=4000
# Filesystem path for uploaded profile images
UPLOAD_PATH=./uploads/profile_images/
