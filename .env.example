CI_ENV=development
BASE_URL=http://localhost/alumni-influencers/

DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=alumni_platform

ENCRYPTION_KEY=change-this-to-a-long-random-secret
UNIVERSITY_DOMAIN=westminster.ac.uk
SESSION_TIMEOUT=7200
LOG_THRESHOLD=2
RATE_LIMIT=60
CORS_ALLOWED_ORIGIN=http://localhost

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_CRYPTO=tls
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@westminster.ac.uk
SMTP_FROM_NAME=Alumni Influencers Platform

VERIFICATION_TOKEN_EXPIRY=24
RESET_TOKEN_EXPIRY=1

DEFAULT_API_SCOPE=read:alumni,read:analytics
ANALYTICS_DASHBOARD_TOKEN=replace-with-admin-created-bearer-token

MAX_FEATURES_PER_MONTH=3

UPLOAD_PATH=./uploads/profile_images/
MAX_IMAGE_SIZE=2048
MAX_IMAGE_WIDTH=4000
MAX_IMAGE_HEIGHT=4000
